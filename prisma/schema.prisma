// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Prediction {
  id             String   @id
  team1          String
  team2          String
  team1Id        Int      @map("team1_id")
  team2Id        Int      @map("team2_id")
  predictedWinner String  @map("predicted_winner")
  confidence     Int
  predictedScore String   @map("predicted_score")
  actualWinner   String?  @map("actual_winner")
  actualScore    String?  @map("actual_score")
  correct        Boolean?
  gameDate       String?  @map("game_date")
  gameId         Int?     @map("game_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("predictions")
}
